    "//:common",
    "//acl_loader",
    "//clear",
    "//clear/plugins",
    "//clear/plugins/auto",
    "//config",
    "//config/plugins",
    "//config/plugins/auto",
    "//connect",
    "//consutil",
    "//counterpoll",
    "//crm",
    "//debug",
    "//dump",
    "//fdbutil",
    "//flow_counter_util",
    "//fwutil",
    "//generic_config_updater",
    "//pcieutil",
    "//pddf_fanutil",
    "//pddf_ledutil",
    "//pddf_psuutil",
    "//pddf_thermalutil",
    "//pfc",
    "//pfcwd",
    "//psuutil",
    "//rcli",
    "//sfputil",
    "//show",
    "//show/interfaces",
    "//show/plugins",
    "//show/plugins/auto",
    "//sonic_cli_gen",
    "//sonic_installer",
