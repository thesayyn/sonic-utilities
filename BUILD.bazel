        "@sonic_utilities_pip//scp",
        "@sonic_utilities_pip//sonic_config_engine",
        "@sonic_utilities_pip//sonic_platform_common",
        "@sonic_utilities_pip//sonic_py_common",
        "@sonic_utilities_pip//sonic_yang_mgmt",
        # Test dependencies
        "@sonic_utilities_pip//responses",
        "@sonic_utilities_pip//deepdiff",
        "@sonic_utilities_pip//mock",
        "@sonic_utilities_pip//mockredispy",
        "@sonic_utilities_pip//pytest",
        "@sonic_utilities_pip//pyfakefs",
