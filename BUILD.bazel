    "//ssdutil",
    "//syslog_util",
    "//undebug",
    "//utilities_common",
    "//watchdogutil",
]

# Package containing all the script files.
tar(
    name = "scripts_pkg",
    srcs = [
        "//scripts:srcs",
    ],
    mutate = mutate(
        package_dir = "./usr/lib/python3/dist-packages",
        strip_prefix = package_name(),
    ),
)

py_library(
    name = "sonic-utilities",
    deps = libs_in_wheel,
    visibility = ["//visibility:public"],
)

# Python source packages from [tool.setuptools].packages in pyproject.toml.
# Uses the same strip_prefix as deps_dist because aspect_rules_py installs
# source packages into the same site-packages layout.
#
# TODO(bazel-ready): The interface with export_py_info should be merged into rules_py.
site_packages(
    name = "libs_dist",
    srcs = libs_in_wheel,
)

# Non-Python package data files from [tool.setuptools.package-data] in pyproject.toml.
tar(
    name = "pkg_data",
    srcs = [
        "//generic_config_updater:pkg_data",
        "//show:pkg_data",
        "//sonic_installer:pkg_data",
    ],
    mutate = mutate(
        package_dir = "./usr/lib/python3/dist-packages",
        strip_prefix = package_name(),
    ),
)

# Combined archive of all relevant sources.
# When expanded into an image, it should replicate how a wheel would be installed.
flatten(
    name = "dist",
    tars = [
        ":libs_dist",
        ":scripts_pkg",
        ":pkg_data",
        "@bookworm//python3-m2crypto:data",
    ],
    visibility = ["//visibility:public"],
    deduplicate = True,
)

assert_tar(
    name = "libs_dist_test",
    tar = ":libs_dist",
    expected = "testdata/libs_dist.expected.txt",
    inconsistent_sizes = ["./usr/lib/python3/dist-packages/libyang.so"],
)

assert_tar(
    name = "pkg_data_test",
    tar = ":pkg_data",
    expected = "testdata/pkg_data.expected.txt",
)

assert_tar(
    name = "dist_test",
    tar = ":dist",
    expected = "testdata/dist.expected.txt",
    inconsistent_sizes = ["./usr/lib/python3/dist-packages/libyang.so"],
)
