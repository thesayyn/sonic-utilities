# Targets that have to be globbed in //:common to avoid cycles
#
# gazelle:resolve_regexp py ^utilities_common$ //:common
# gazelle:resolve_regexp py ^utilities_common\. //:common
# gazelle:resolve_regexp py ^dump$ //:common
# gazelle:resolve_regexp py ^dump\. //:common
# gazelle:resolve_regexp py ^dump\.plugins$ //:common
# gazelle:resolve_regexp py ^dump\.plugins\. //:common
gazelle(
    name = "gazelle",
    gazelle = "@multitool//tools/gazelle",
)

# There is a dependency cycle between utilities_common, dump and dump/plugins.
# We create a unified target with the relevant sources and tell gazelle to depend on that
# instead of the individual libraries.
py_library(
    name = "common",
    srcs = [
        "//dump:srcs",
        "//utilities_common:srcs",
    ],
    visibility = ["//:__subpackages__"],
    deps = [
        "//:all_deps",
    ],
)

py_library(
    name = "all_deps",
    visibility = ["//:__subpackages__"],
    deps = [
        "//scripts:scripts_srcs",  # keep
        "@sonic_utilities_pip//bcrypt",
        "@sonic_utilities_pip//click",
        "@sonic_utilities_pip//cryptography",
        "@sonic_utilities_pip//urllib3",
        "@sonic_utilities_pip//click_log",
        "@sonic_utilities_pip//docker",
        "@sonic_utilities_pip//docker_image_py",
        "@sonic_utilities_pip//filelock",
        "@sonic_utilities_pip//enlighten",
        "@sonic_utilities_pip//ijson",
        "@sonic_utilities_pip//ipaddress",
        "@sonic_utilities_pip//protobuf",
